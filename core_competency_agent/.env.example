# ─────────────────────────────────────────────
#  Agent 6 — Core Competency Agent
#  Copy to .env and fill in your keys.
#  Never commit .env to version control.
# ─────────────────────────────────────────────

# ── Database (Neon PostgreSQL — ontology DB with 10-K filings) ──────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL_ONTOLOGY_LAB=postgresql://user:password@host/dbname?sslmode=require

# ── Anthropic (LLM Interpreter) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Tavily (Competitive Context) ─────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── Agent Settings ────────────────────────────────────────────────────────────
DEFAULT_QUARTERS=8
RAG_ENABLED=true
NEON_TOP_K=6
