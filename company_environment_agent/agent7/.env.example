DATABASE_URL=postgresql://user:password@localhost:5432/agent7

# Optional: csi_ontology_lab — enables 10-K retrieval via hybrid BM25+vector search.
# Without this the agent falls back to its local risk_factors table.
DATABASE_URL_ONTOLOGY_LAB=postgresql://user:password@host/csi_ontology_lab?sslmode=require

ANTHROPIC_API_KEY=sk-ant-...
TAVILY_API_KEY=tvly-...
ANTHROPIC_MODEL=claude-opus-4-7
EMBEDDING_MODEL=voyage-large-2  # or sentence-transformers fallback
