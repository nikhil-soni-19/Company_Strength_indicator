# ─────────────────────────────────────────────
#  Agent 10 — Company Performance Agent
#  Copy to .env and fill in your keys.
#  Never commit .env to version control.
# ─────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose "openai" or "anthropic"
LLM_PROVIDER=openai

# OpenAI (used for both LLM reasoning and embeddings)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic (alternative — set LLM_PROVIDER=anthropic to use)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Neon Database (RAG layer) ─────────────────────────────────────────────────
DATABASE_URL_ONTOLOGY_LAB=postgresql://user:password@host/dbname?sslmode=require

# Set to true to activate RAG retrieval from Neon
RAG_ENABLED=true

# ── RAG Retrieval Settings ────────────────────────────────────────────────────
NEON_TOP_K=8

# ── Agent Settings ────────────────────────────────────────────────────────────
DEFAULT_QUARTERS=8
