# ── Database (Neon PostgreSQL) ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL_ONTOLOGY_LAB=postgresql://user:password@host/dbname?sslmode=require

# ── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
